    {
        "text": "this is the actual linear time solution",
        "start": 726.959,
        "duration": 8.801,
        "code": [
            "class Solution:",
            "def maxArea(self, heights: List[int]) -> int:",
            "    l, r = 0, len(heights) - 1",
            "    res = 0",
            "    while l < r:",
            "        res = max(res, min(heights[l], heights[r]) * (r - l))",
            "        if heights[l] < heights[r]:",
            "            l += 1",
            "        elif heights[r] <= heights[l]:",
            "            r -= 1",
            "    return res"
        ]
    }
